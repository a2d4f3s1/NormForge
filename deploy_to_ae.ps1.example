# NormForge - After Effects deploy script (template)
#
# Copy this file to "deploy_to_ae.ps1" in the same directory and adjust the
# paths below to match your local environment, then run with administrator
# privileges (writes to Program Files).
#
#   Copy-Item deploy_to_ae.ps1.example deploy_to_ae.ps1
#   gsudo powershell -File .\deploy_to_ae.ps1
#
# The actual deploy_to_ae.ps1 is gitignored so each developer can keep
# environment-specific paths locally.

# ----- Local build output directory (Debug or Release) -----
$buildDir   = "$PSScriptRoot\build\Debug"

# ----- After Effects deploy paths -----
# Plugin folder layout (since 0.6.15): everything (.aex + cudart64_12.dll)
# goes into a single subfolder under Plug-ins\, like industry-standard AE
# plugins (Element 3D, Saber, etc.). The plugin's EffectMain calls
# SetDllDirectory at runtime so that the delay-loaded cudart64_12.dll
# resolves from this same folder.
$dest       = "C:\Program Files\Adobe\Adobe After Effects 2024\Support Files\Plug-ins\NormForge\"
$aexPath    = "C:\Program Files\Adobe\Adobe After Effects 2024\Support Files\AfterFX.exe"

# ----- CUDA Runtime DLL -----
$cudartDll  = "$env:CUDA_PATH\bin\cudart64_12.dll"

# ----- Pre-flight check -----
if (-not (Test-Path "$buildDir\NormForge.aex")) {
    Write-Error "NormForge.aex not found. Build first: $buildDir"
    exit 1
}

# ----- Stop AE if running (so the .aex file is not locked) -----
$ae = Get-Process -Name "AfterFX" -ErrorAction SilentlyContinue
if ($ae) {
    Write-Host "Stopping AE..."
    $ae | Stop-Process -Force
    Start-Sleep -Seconds 2
}

# ----- Create NormForge\ folder if it doesn't exist -----
if (-not (Test-Path $dest)) {
    Write-Host "Creating folder: $dest"
    New-Item -ItemType Directory -Path $dest -Force | Out-Null
}

# ----- Copy plugin files into NormForge\ -----
foreach ($file in @("NormForge.aex", "NormForge.pdb")) {
    $src = "$buildDir\$file"
    if (Test-Path $src) {
        Write-Host "Copy: $src -> $dest"
        Copy-Item $src $dest -Force
    }
}

# ----- Copy CUDA Runtime DLL alongside the .aex -----
if (Test-Path $cudartDll) {
    Write-Host "Copy: $cudartDll -> $dest"
    Copy-Item $cudartDll $dest -Force
} else {
    Write-Warning "CUDA Runtime DLL not found: $cudartDll  (CUDA Toolkit not installed?)"
}

# ----- (Optional) Clean up legacy 0.6.14 layout -----
# Older versions of NormForge placed the .aex directly under Plug-ins\ and
# the DLL under Support Files\. Remove those if they exist so AE doesn't
# pick up the old binary.
$oldAexPath = "C:\Program Files\Adobe\Adobe After Effects 2024\Support Files\Plug-ins\NormForge.aex"
$oldPdbPath = "C:\Program Files\Adobe\Adobe After Effects 2024\Support Files\Plug-ins\NormForge.pdb"
$oldDllPath = "C:\Program Files\Adobe\Adobe After Effects 2024\Support Files\cudart64_12.dll"
foreach ($oldPath in @($oldAexPath, $oldPdbPath, $oldDllPath)) {
    if (Test-Path $oldPath) {
        Write-Host "Removing legacy file: $oldPath"
        Remove-Item $oldPath -Force -ErrorAction SilentlyContinue
    }
}

# ----- Restart AE -----
Write-Host "Starting AE..."
Start-Process $aexPath
Write-Host "Done."
